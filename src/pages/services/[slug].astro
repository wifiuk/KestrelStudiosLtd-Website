---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import IncludedItem from '../../components/IncludedItem.astro';
import DeliverableCard from '../../components/DeliverableCard.astro';
import CTASection from '../../components/CTASection.astro';
import { services } from '../../data/services';
import { defaultSiteUrl, siteName } from '../../data/site';

export function getStaticPaths() {
  return services.map(service => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;

// Build hero title with highlight
const heroTitleHtml = service.heroTitle.replace(
  service.highlightWord,
  `<span class="text-orange">${service.highlightWord}</span>`
);

const serviceUrl = `${defaultSiteUrl}/services/${service.slug}/`;
const serviceImage = `${defaultSiteUrl}${service.heroImage ?? '/property_image1.png'}`;
const faqItems = [
  {
    question: `Who is ${service.title.toLowerCase()} for?`,
    answer: service.audience.map((item) => `${item.name}: ${item.detail}`).join(' '),
  },
  {
    question: `What do you receive with ${service.title.toLowerCase()}?`,
    answer: service.deliverables.map((item) => `${item.title}: ${item.description}`).join(' '),
  },
  {
    question: `Do you provide ${service.title.toLowerCase()} in Kent?`,
    answer: `Yes. Kestrel Studios provides ${service.title.toLowerCase()} for clients across Kent and the South East. Each project is scoped individually so the quote reflects the site, output requirements and deliverables needed.`,
  },
];

const serviceStructuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    '@id': `${serviceUrl}#service`,
    name: service.title,
    description: service.summary,
    url: serviceUrl,
    image: serviceImage,
    provider: {
      '@type': 'ProfessionalService',
      '@id': `${defaultSiteUrl}/#business`,
      name: siteName,
      url: defaultSiteUrl,
    },
    areaServed: {
      '@type': 'AdministrativeArea',
      name: 'Kent and the South East',
    },
    serviceType: service.title,
    offers: {
      '@type': 'Offer',
      availability: 'https://schema.org/InStock',
      priceSpecification: {
        '@type': 'PriceSpecification',
        priceCurrency: 'GBP',
      },
      url: `${defaultSiteUrl}/quote/`,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: `${defaultSiteUrl}/`,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Services',
        item: `${defaultSiteUrl}/#services`,
      },
      {
        '@type': 'ListItem',
        position: 3,
        name: service.title,
        item: serviceUrl,
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    })),
  },
];
---

<BaseLayout
  title={`${service.title} in Kent`}
  description={service.summary}
  image={service.heroImage ?? '/property_image1.png'}
  structuredData={serviceStructuredData}
>

  <!-- HERO -->
  <section class="relative pt-28 pb-20 px-6 lg:px-12 overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_20%_50%,rgba(224,98,24,0.06)_0%,transparent_50%)]"></div>
    <div class="absolute bottom-0 left-0 right-0 h-28 bg-gradient-to-t from-bg to-transparent"></div>

    <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-16 items-center relative z-10">
      <div class="flex-1">
        <div class="font-barlow-condensed text-[13px] font-medium uppercase tracking-[1.5px] text-muted mb-5">
          Services <span class="text-orange">&rarr;</span> {service.title}
        </div>
        <h1 class="font-bebas text-[clamp(2.8rem,5vw,4rem)] leading-[0.95] tracking-[2px] mb-5" set:html={heroTitleHtml} />
        <p class="text-[17px] font-light text-silver leading-relaxed mb-7 max-w-lg">{service.summary}</p>
        <Button href="/quote">Request a Quote</Button>
      </div>
      <div class="flex-1 w-full">
        <div class="aspect-[4/3] rounded-lg overflow-hidden">
          <img src={service.heroImage ?? '/property_image1.png'} alt={`${service.title} aerial image`} class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT'S INCLUDED -->
  <section class="bg-alt-bg py-24 px-6 lg:px-12">
    <div class="max-w-7xl mx-auto">
      <SectionHeader
        label="What's Included"
        title="EVERYTHING YOU NEED"
      />
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mt-10">
        {service.includes.map(item => (
          <IncludedItem title={item.title} description={item.description} />
        ))}
      </div>
    </div>
  </section>

  <!-- WHO IT'S FOR -->
  <section class="py-24 px-6 lg:px-12">
    <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-16 items-center">
      <div class="flex-1">
        <SectionHeader
          label="Who It's For"
          title="BUILT FOR YOUR SECTOR"
        />
        <ul class="mt-8 space-y-0">
          {service.audience.map(item => (
            <li class="py-4 border-b border-border-subtle flex items-start gap-3.5 text-silver">
              <span class="w-2 h-2 bg-orange rounded-sm rotate-45 mt-1.5 shrink-0"></span>
              <span><strong class="text-cream font-medium">{item.name}</strong> — {item.detail}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="flex-1 w-full">
        <div class={`${service.sectionImagePortrait ? 'aspect-[2/3]' : 'aspect-[4/3]'} rounded-lg overflow-hidden`}>
          <img src={service.sectionImage ?? '/property_image2.png'} alt={`${service.title} example`} class={`w-full h-full object-cover ${service.sectionImagePortrait ? 'object-top' : 'object-center'}`} />
        </div>
      </div>
    </div>
  </section>

  <!-- DELIVERABLES -->
  <section class="bg-alt-bg py-24 px-6 lg:px-12">
    <div class="max-w-7xl mx-auto">
      <SectionHeader
        label="Example Deliverables"
        title="WHAT YOU COULD RECEIVE"
      />
      <p class="text-sm text-muted max-w-xl leading-relaxed mt-[-8px]">
        Deliverables vary depending on your project scope and quote. Below are examples of what we can provide.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-10">
        {service.deliverables.map(item => (
          <DeliverableCard title={item.title} description={item.description} formats={item.formats} />
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-24 px-6 lg:px-12">
    <div class="max-w-7xl mx-auto">
      <SectionHeader
        label="Common Questions"
        title="SERVICE FAQ"
      />
      <div class="mt-10 divide-y divide-border-subtle border-y border-border-subtle">
        {faqItems.map((item) => (
          <details class="group py-6">
            <summary class="cursor-pointer list-none font-barlow-condensed text-lg font-semibold uppercase tracking-wide text-cream flex items-center justify-between gap-6">
              <span>{item.question}</span>
              <span class="text-orange group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="mt-4 text-sm text-muted leading-relaxed max-w-3xl">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTASection
    title={`NEED ${service.title.toUpperCase().split(' ').slice(0, 3).join(' ')}?`}
    description="Tell us about your project and we'll put together a quote. No obligation, fast response."
  />

</BaseLayout>
